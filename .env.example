SPRING_DATASOURCE_USERNAME=pmt_user
SPRING_DATASOURCE_PASSWORD=pmt_password

# Redis Configuration
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# JWT Configuration
